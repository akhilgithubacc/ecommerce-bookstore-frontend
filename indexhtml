<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PageTurner - AI Engineered Bookstore</title>
    <!-- Tailwind CSS Play CDN for instant browser compilation -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-900 font-sans relative overflow-x-hidden">

    <!-- 1. RESPONSIVE NAVIGATION -->
    <nav class="bg-white shadow-sm sticky top-0 z-40">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-2">
                    <span class="text-2xl">📚</span>
                    <span class="font-bold text-xl tracking-tight text-indigo-600">PageTurner</span>
                </div>
                <!-- Search Bar -->
                <div class="hidden md:flex flex-1 max-w-md mx-8">
                    <input type="text" placeholder="Search books..." class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm">
                </div>
                <!-- Cart Trigger Button -->
                <div class="flex items-center gap-4">
                    <button onclick="toggleCart()" class="relative p-2 text-gray-600 hover:text-indigo-600 transition-colors cursor-pointer">
                        <span class="text-xl">🛒</span>
                        <span class="absolute top-0 right-0 bg-indigo-600 text-white text-xs font-bold rounded-full h-4 w-4 flex items-center justify-center">2</span>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- 2. HERO BANNER -->
    <header class="bg-gradient-to-r from-indigo-600 to-purple-700 text-white py-12 md:py-20 px-4 text-center">
        <div class="max-w-3xl mx-auto">
            <h1 class="text-3xl md:text-5xl font-extrabold mb-4">Your Next Adventure Awaits</h1>
            <p class="text-indigo-100 text-base md:text-lg mb-6">Explore titles selected and curated with agentic design workflows.</p>
            <button class="bg-white text-indigo-700 font-semibold px-6 py-3 rounded-lg shadow hover:bg-indigo-50 transition-all">Browse Collection</button>
        </div>
    </header>

    <!-- 3. MAIN ECOMMERCE GRID -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <h2 class="text-2xl font-bold mb-8 text-gray-800 border-b pb-2">Trending Books</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            
            <!-- Book Card 1 -->
            <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100 hover:shadow-lg transition-shadow flex flex-col justify-between">
                <div class="p-4 bg-gray-100 h-64 flex items-center justify-center"><span class="text-6xl">🤖</span></div>
                <div class="p-5 flex-1 flex flex-col justify-between">
                    <div>
                        <span class="text-xs font-semibold uppercase tracking-wider text-indigo-600 bg-indigo-50 px-2 py-1 rounded">Technology</span>
                        <h3 class="font-bold text-lg mt-2 text-gray-900">Designing with Agents</h3>
                    </div>
                    <div class="mt-4 flex items-center justify-between">
                        <span class="text-xl font-bold text-gray-900">$29.99</span>
                        <button onclick="toggleCart()" class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-4 py-2 rounded-md transition-colors cursor-pointer">Add to Cart</button>
                    </div>
                </div>
            </div>

            <!-- Book Card 2 -->
            <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100 hover:shadow-lg transition-shadow flex flex-col justify-between">
                <div class="p-4 bg-gray-100 h-64 flex items-center justify-center"><span class="text-6xl">🎨</span></div>
                <div class="p-5 flex-1 flex flex-col justify-between">
                    <div>
                        <span class="text-xs font-semibold uppercase tracking-wider text-purple-600 bg-purple-50 px-2 py-1 rounded">Design</span>
                        <h3 class="font-bold text-lg mt-2 text-gray-900">Responsive UI Layouts</h3>
                    </div>
                    <div class="mt-4 flex items-center justify-between">
                        <span class="text-xl font-bold text-gray-900">$24.50</span>
                        <button onclick="toggleCart()" class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-4 py-2 rounded-md transition-colors cursor-pointer">Add to Cart</button>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <!-- 4. INTERACTIVE SLIDE-OVER SHOPPING CART SIDEBAR -->
    <!-- Backdrop overlay shadow -->
    <div id="cartBackdrop" onclick="toggleCart()" class="fixed inset-0 bg-black/50 z-40 hidden transition-opacity duration-300 opacity-0"></div>
    
    <!-- Sidebar Element -->
    <div id="sidebarCart" class="fixed inset-y-0 right-0 max-w-full w-full sm:max-w-md bg-white shadow-2xl z-50 transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col">
        <!-- Header -->
        <div class="p-6 border-b border-gray-200 flex items-center justify-between">
            <h2 class="text-lg font-bold text-gray-900">Shopping Cart</h2>
            <button onclick="toggleCart()" class="text-gray-400 hover:text-gray-500 p-2 text-xl cursor-pointer">✕</button>
        </div>
        <!-- Cart Items -->
        <div class="flex-1 overflow-y-auto p-6 space-y-6">
            <!-- Item 1 -->
            <div class="flex items-center gap-4 border-b pb-4 border-gray-100">
                <div class="w-16 h-16 bg-gray-100 rounded flex items-center justify-center text-2xl">🤖</div>
                <div class="flex-1">
                    <h4 class="font-medium text-sm text-gray-900">Designing with Agents</h4>
                    <p class="text-gray-500 text-xs">Qty 1</p>
                </div>
                <span class="font-semibold text-sm">$29.99</span>
            </div>
            <!-- Item 2 -->
            <div class="flex items-center gap-4 border-b pb-4 border-gray-100">
                <div class="w-16 h-16 bg-gray-100 rounded flex items-center justify-center text-2xl">🎨</div>
                <div class="flex-1">
                    <h4 class="font-medium text-sm text-gray-900">Responsive UI Layouts</h4>
                    <p class="text-gray-500 text-xs">Qty 1</p>
                </div>
                <span class="font-semibold text-sm">$24.50</span>
            </div>
        </div>
        <!-- Footer Checkout Section -->
        <div class="p-6 border-t border-gray-200 bg-gray-50">
            <div class="flex justify-between font-semibold text-base text-gray-900 mb-4">
                <span>Subtotal</span>
                <span>$54.49</span>
            </div>
            <button class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-3 rounded-lg transition-colors shadow">Proceed to Checkout</button>
        </div>
    </div>

    <!-- 5. FOOTER -->
    <footer class="bg-gray-900 text-gray-400 py-8 border-t border-gray-800 mt-20">
        <div class="max-w-7xl mx-auto px-4 text-center text-sm">
            <p>&copy; 2026 PageTurner Bookstore Front-end.</p>
        </div>
    </footer>

    <!-- 6. SIDEBAR JAVASCRIPT CONTROLLER -->
    <script>
        function toggleCart() {
            const sidebar = document.getElementById('sidebarCart');
            const backdrop = document.getElementById('cartBackdrop');
            
            if (sidebar.classList.contains('translate-x-full')) {
                // Open Sidebar
                sidebar.classList.remove('translate-x-full');
                backdrop.classList.remove('hidden');
                setTimeout(() => backdrop.classList.add('opacity-100'), 10);
                document.body.style.overflow = 'hidden'; // Stop page scrolling background
            } else {
                // Close Sidebar
                sidebar.classList.add('translate-x-full');
                backdrop.classList.remove('opacity-100');
                setTimeout(() => backdrop.classList.add('hidden'), 300);
                document.body.style.overflow = ''; // Re-enable scrolling
            }
        }
    </script>
</body>
</html>
